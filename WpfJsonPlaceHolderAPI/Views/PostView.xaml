<UserControl x:Class="WpfJsonPlaceHolderAPI.Views.PostView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfJsonPlaceHolderAPI.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
<RowDefinition Height="*" />
<RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="1">
            <Button Content="Get Post" Margin="3,3,3,3" Height="40" FontWeight="Bold" FontSize="20" Command="{Binding PostCommand}"/>
        </StackPanel>

        <ListBox Grid.Row="0" ItemsSource="{Binding AllPosts}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="{Binding Id,StringFormat = Post Id: {0}}"/>
                        <TextBlock>
                            <Run Text="User Id :"/>
                            <Run Text="{Binding UserId}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Foreground="Brown"/>
                        <TextBlock Text="{Binding Body}" FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
