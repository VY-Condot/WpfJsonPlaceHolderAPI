<Window x:Class="WpfJsonPlaceHolderAPI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfJsonPlaceHolderAPI"
        xmlns:views="clr-namespace:WpfJsonPlaceHolderAPI.Views" xmlns:vm="clr-namespace:WpfJsonPlaceHolderAPI.ViewModels"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    
    <!-- set datacontext -->
    <Window.DataContext>
        <!--<vm:PostViewModel/>-->
        <vm:MainWindowViewModel/>
    </Window.DataContext>
    
    <Grid>
        <!-- Drop in your PostView user control --><!--
        <views:PostView />-->
        
        <!-- host the tabview -->
        <TabControl Name="TabView">
            <TabItem Header="Posts">
                <views:PostView DataContext="{Binding PostView}"/>
            </TabItem>
            <TabItem Header="Comments">
                <views:CommentView DataContext="{Binding CommentView}"/>
            </TabItem>
        </TabControl>

    </Grid>
</Window>
